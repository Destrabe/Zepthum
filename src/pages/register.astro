---
import Layout from "../layouts/LoginLayout.astro";
import "../styles/register.css";
---

<Layout title="Register">
  <div class="split-container">
    <div class="left-side">
      <div class="container">
        <!--Logo -->
        <div class="logo">
          <img src="/src/assets/svg/logo_tem.svg" class="logo-img" alt="Logo" />
          <span class="logo-name">Empresa</span>
        </div>
        <!--Texto de bienvenida -->
        <span class="welcome-text">
          Bienvenido a la plataforma de gestión de puntos.
        </span>
        <!--Formulario -->
        <div class="form-container">
          <h1>Crea una cuenta</h1>
          <form>
            <div class="input-group">
              <label for="username">Usuario</label>
              <input type="text" id="username" name="username" required />
            </div>
            <div class="input-group">
              <label for="correo">correo</label>
              <input type="email" id="correo" name="email" required />
            </div>
            <div class="input-group">
              <label for="password">Contraseña</label>
              <input type="password" id="password" name="password" required />
            </div>
            <button id="submit" type="submit">Crear Cuenta</button>
          </form>
        </div>
        <div class="iniciar-sesion">
          <a href="/login">Inicia sesion ahora</a>
        </div>
      </div>
    </div>
    <div class="right-side">
      <img src="/src/assets/images/kirby.jpg" alt="Ilustración login" />
    </div>
  </div>
</Layout>
